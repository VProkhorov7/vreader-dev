{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "model": "sonnet",
    "env": {
        "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "40",
        "CLAUDE_CODE_SUBAGENT_MODEL": "haiku",
        "CLAUDE_CODE_EFFORT_LEVEL": "low"
    },
    "permissions": {
        "defaultMode": "acceptEdits",
        "allow": [
            "Read",
            "Bash(ls *)",
            "Bash(pwd)",
            "Bash(git status)",
            "Bash(git diff *)",
            "Bash(rg --max-filesize 200k *)",
            "Bash(find . -maxdepth 3 *)"
        ],
        "ask": [
            "Bash(rg *)",
            "Bash(find *)",
            "Bash(git add *)",
            "Bash(git commit *)",
            "Bash(git push *)",
            "Bash(npm *)",
            "Bash(chmod *)"
        ],
        "deny": [
            "Read(./.env)",
            "Read(./.env.*)",
            "Read(./secrets/**)",
            "Bash(rm -rf *)",
            "Bash(sudo *)",
            "Bash(curl * | sh *)",
            "Bash(wget * | sh *)"
        ],
        "autoApplyEdits": true,
        "showDiffs": false
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/block-danger.sh",
                        "timeout": 5
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/format-touched.sh",
                        "timeout": 10
                    }
                ]
            }
        ]
    }
}